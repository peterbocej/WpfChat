<Window x:Class="WpfChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfChat"
        mc:Ignorable="d"
        xmlns:vm="clr-namespace:WpfChat.ViewModel"
        Title="{Binding Title}" 
        Height="450" Width="800"
        Closed="Window_Closed">
   <Window.DataContext>
      <vm:MainWindowVM/>
   </Window.DataContext>
   <Grid Margin="5">
      <Grid.RowDefinitions>
         <RowDefinition Height="30"/>
         <RowDefinition Height="60"/>
         <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <ToolBar Grid.Row="0">
         <TextBlock Text="User:" Margin="2" VerticalAlignment="Center"/>
         <TextBox x:Name="tbUser" Text="{Binding UserName, Mode=TwoWay}" VerticalAlignment="Center" Width="80"/>
         <Button x:Name="btRefresh" Content="Refresh" Click="btRefresh_Click" VerticalAlignment="Center" Width="60"/>
      </ToolBar>

      <Grid Grid.Row="1">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto"/>
         </Grid.ColumnDefinitions>
         <TextBox x:Name="tbMessage"
                  AcceptsReturn="True"
                  TextWrapping="Wrap"
                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                  Text="{Binding MessageText, Mode=TwoWay}"
                  Grid.Column="0"/>
         <Button x:Name="btSend"
                 Content="Send ->"
                 Click="btSend_Click"
                 Grid.Column="1"
                 Height="20"
                 VerticalAlignment="Bottom"/>
      </Grid>

      <DataGrid x:Name="gdMessages" Grid.Row="2"
                ItemsSource="{Binding Messages}"
                AutoGenerateColumns="False"
                HeadersVisibility="None"
                BorderThickness="0"
                GridLinesVisibility="None"
                RowBackground="White"
                IsReadOnly="True"
                SelectionMode="Single"
                Focusable="False"
                SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}">
         <DataGrid.Columns>
            <DataGridTextColumn Binding="{Binding FromAndTime}" Width="Auto">
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                     <Setter Property="TextWrapping" Value="Wrap"/>
                     <Style.Triggers>
                        <DataTrigger Binding="{Binding Me}" Value="1">
                           <Setter Property="Background" Value="#FFFCFFCB"/>
                           <Setter Property="Foreground" Value="Black"/>
                        </DataTrigger>
                     </Style.Triggers>
                  </Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding Body}" Width="*">
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                     <Setter Property="TextWrapping" Value="Wrap"/>
                     <Style.Triggers>
                        <DataTrigger Binding="{Binding Me}" Value="1">
                           <Setter Property="Background" Value="#FFFCFFCB"/>
                           <Setter Property="Foreground" Value="Black"/>
                        </DataTrigger>
                     </Style.Triggers>
                  </Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
         </DataGrid.Columns>
      </DataGrid>
   </Grid>
</Window>
